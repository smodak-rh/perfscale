{
  "description": "Dashboard for tracking error trends.",
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineInterpolation": "smooth",
            "stacking": {
              "mode": "normal"
            }
          },
          "decimals": 0,
          "min": 0,
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "passes"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failures"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 13,
        "w": 24
      },
      "id": 1,
      "pluginVersion": "v11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "format": "time_series",
          "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COUNT(*) AS \"passes\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND $__timeFilter(start)\n    AND label_values->>'.results.measurements.KPI.mean' != '-1'\nGROUP BY 1\nORDER BY 1;\n"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "format": "time_series",
          "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COUNT(*) AS \"failures\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND $__timeFilter(start)\n    AND label_values->>'.results.measurements.KPI.mean' = '-1'\nGROUP BY 1\nORDER BY 1;\n"
        }
      ],
      "title": "Runs count grand total",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 20,
            "lineInterpolation": "stepBefore",
            "stacking": {
              "mode": "normal"
            }
          },
          "decimals": 0,
          "min": 0,
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 13,
        "w": 24,
        "y": 13
      },
      "id": 2,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "v11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "format": "time_series",
          "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COALESCE(\n        CASE\n            WHEN label_values ? '__results_errors_error_reasons_simple' AND label_values->>'__results_errors_error_reasons_simple' = '' THEN\n                'no error detected'\n            WHEN label_values ? '__results_errors_error_reasons_simple' THEN\n                regexp_replace(label_values->>'__results_errors_error_reasons_simple', '[0-9]+[[:space:]]?x ', '', 'g')\n            ELSE\n                NULL\n        END,\n        NULL) AS \"metric\",\n    COUNT(*) AS \"count\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND label_values ? '__results_errors_error_reasons_simple'\n    AND label_values->>'__results_errors_error_reasons_simple' != ''\n    AND $__timeFilter(start)\nGROUP BY 1,2\nORDER BY 1;\n"
        }
      ],
      "title": "Errors by reason grand total",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 20,
            "lineInterpolation": "stepBefore",
            "stacking": {
              "mode": "normal"
            }
          },
          "decimals": 0,
          "min": 0,
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 13,
        "w": 24,
        "y": 26
      },
      "id": 3,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "v11.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "format": "time_series",
          "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COALESCE(\n        CASE\n            WHEN label_values ? '__results_errors_error_caused_by_simple' AND label_values->>'__results_errors_error_caused_by_simple' = '' THEN\n                'no error detected'\n            WHEN label_values ? '__results_errors_error_caused_by_simple' THEN\n                label_values->>'__results_errors_error_caused_by_simple'\n            ELSE\n                NULL\n        END,\n        NULL) AS \"metric\",\n    COUNT(*) AS \"count\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND label_values ? '__results_errors_error_caused_by_simple'\n    AND label_values->>'__results_errors_error_caused_by_simple' != ''\n    AND $__timeFilter(start)\nGROUP BY 1,2\nORDER BY 1;\n"
        }
      ],
      "title": "Errors by cause grand total",
      "type": "timeseries"
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "id": 4,
      "panels": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${datasource}"
          },
          "fieldConfig": {
            "defaults": {
              "custom": {
                "fillOpacity": 20,
                "lineInterpolation": "smooth",
                "showPoints": "always",
                "spanNulls": 3600000,
                "stacking": {
                  "mode": "normal"
                }
              },
              "decimals": 0,
              "min": 0,
              "unit": "none"
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "passes"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "fixedColor": "green",
                      "mode": "fixed"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "failures"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "fixedColor": "red",
                      "mode": "fixed"
                    }
                  }
                ]
              }
            ]
          },
          "gridPos": {
            "h": 9,
            "w": 6
          },
          "id": 5,
          "pluginVersion": "v11.4.0",
          "repeat": "member_cluster",
          "targets": [
            {
              "datasource": {
                "type": "postgres",
                "uid": "${datasource}"
              },
              "format": "time_series",
              "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COUNT(*) AS \"passes\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND rtrim(label_values->>'.metadata.env.MEMBER_CLUSTER', '/') = rtrim(${member_cluster}, '/')\n    AND $__timeFilter(start)\n    AND label_values->>'.results.measurements.KPI.mean' != '-1'\nGROUP BY 1\nORDER BY 1;\n"
            },
            {
              "datasource": {
                "type": "postgres",
                "uid": "${datasource}"
              },
              "format": "time_series",
              "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COUNT(*) AS \"failures\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND rtrim(label_values->>'.metadata.env.MEMBER_CLUSTER', '/') = rtrim(${member_cluster}, '/')\n    AND $__timeFilter(start)\n    AND label_values->>'.results.measurements.KPI.mean' = '-1'\nGROUP BY 1\nORDER BY 1;\n"
            }
          ],
          "title": "Runs count for ${member_cluster}",
          "type": "timeseries"
        }
      ],
      "title": "Runs count per cluster",
      "type": "row"
    },
    {
