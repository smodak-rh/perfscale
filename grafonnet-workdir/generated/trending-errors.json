          "pluginVersion": "v11.4.0",
          "repeat": "member_cluster",
          "targets": [
            {
              "datasource": {
                "type": "postgres",
                "uid": "${datasource}"
              },
              "format": "time_series",
              "rawSql": "SELECT\n    $__timeGroupAlias(start, '1h'),\n    COALESCE(\n        CASE\n            WHEN label_values ? '__results_errors_error_reasons_simple' AND label_values->>'__results_errors_error_reasons_simple' = '' THEN\n                'no error detected'\n            WHEN label_values ? '__results_errors_error_reasons_simple' THEN\n                regexp_replace(label_values->>'__results_errors_error_reasons_simple', '[0-9]+[[:space:]]?x ', '', 'g')\n            ELSE\n                NULL\n        END,\n        NULL) AS \"metric\",\n    COUNT(*) AS \"count\"\nFROM\n    data\nWHERE\n    horreum_testid = 372\n    AND rtrim(label_values->>'.metadata.env.MEMBER_CLUSTER', '/') = rtrim(${member_cluster}, '/')\n    AND label_values ? '__results_errors_error_reasons_simple'\n    AND label_values->>'__results_errors_error_reasons_simple' != ''\n    AND $__timeFilter(start)\nGROUP BY 1,2\nORDER BY 1;\n"
            }
          ],
          "title": "Errors by reason for ${member_cluster}",
          "type": "timeseries"
        }
      ],
      "title": "Errors by reason per cluster",
      "type": "row"
    }
  ],
